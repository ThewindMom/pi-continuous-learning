{
  "name": "pi-continuous-learning",
  "description": "A small cursor-based continuous-learning extension for Pi",
  "private": true,
  "type": "module",
  "repository": "https://github.com/ThewindMom/pi-continuous-learning",
  "scripts": {
    "test": "bun test ./test",
    "typecheck": "bunx tsc --noEmit",
    "build": "bun build ./index.ts --target bun --packages external --outdir ./dist",
    "lint": "oxlint index.ts core.ts history.ts graduation.ts security.ts test/*.ts"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "deno": "latest",
    "oxlint": "^1.74.0",
    "pyodide": "latest",
    "typescript": "latest"
  },
  "trustedDependencies": ["deno"]
}
